{
  "name": "@fold/node",
  "version": "0.1.0",
  "description": "Fold — Node.js resources for the unified virtual filesystem",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fold/core": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0",
    "@aws-sdk/client-s3": ">=3.0.0",
    "@slack/web-api": ">=7.0.0",
    "@slack/socket-mode": ">=2.0.0",
    "ioredis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@slack/web-api": {
      "optional": true
    },
    "@slack/socket-mode": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "rimraf": "^6.0.0"
  },
  "keywords": [
    "vfs",
    "virtual-filesystem",
    "ai-agents",
    "fold",
    "nodejs"
  ],
  "author": "Aniket Ghavte",
  "repository": {
    "type": "git",
    "url": "https://github.com/aniketghavte/Fold.git",
    "directory": "packages/node"
  },
  "license": "Apache-2.0"
}
