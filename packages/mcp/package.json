{
  "name": "@fold/mcp",
  "version": "0.1.0",
  "description": "Fold — MCP server that exposes any Workspace to Claude, Cursor, and other MCP clients",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "fold-mcp": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fold/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@fold/node": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@fold/node": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "rimraf": "^6.0.0"
  },
  "keywords": ["mcp", "model-context-protocol", "ai-agents", "fold", "claude", "cursor"],
  "license": "MIT"
}
